# Local dev: copy to `.env` in the repo root (`cp .env.example .env`) and fill in values.
# Never commit `.env` — it is gitignored. Edge Function secrets (AI_COMPAT_*, TOKEN_ENCRYPTION_KEY,
# service role, etc.) live in Supabase Dashboard → Edge Functions → Secrets, not here.
#
# Supabase URL + publishable key + project ref: run `npm run env:supabase` (uses Supabase CLI and
# `supabase/config.toml` project_id). That merges a marked block into `.env`; add Auth0 vars below.

# Required for `npm run dev` (see src/lib/env.ts)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Optional; must match the same project as VITE_SUPABASE_URL if set
VITE_SUPABASE_PROJECT_ID=your-project-ref

VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
# Optional unless you use an Auth0 API audience for access tokens
VITE_AUTH0_AUDIENCE=your-auth0-api-audience
# Optional; include offline_access if you need refresh tokens for long sessions
VITE_AUTH0_SCOPE=openid profile email offline_access
# Optional unless you use in-app password reset (then required)
VITE_AUTH0_DATABASE_CONNECTION=Username-Password-Authentication

# Supabase Edge Functions only (not VITE_): OpenAI-compatible chat completions
# Example (if your gateway exposes this path): https://your-gateway.example.com/v1/chat/completions
# AI_COMPAT_API_URL=
# AI_COMPAT_API_KEY=
